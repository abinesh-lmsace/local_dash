<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/dash/addon/dashboard/db" VERSION="2026012100" COMMENT="XMLDB file for dashaddon_dashboard"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="dashaddon_dashboard_dash" COMMENT="Preconfigured dashboards">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="contextid" TYPE="int" LENGTH="10"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10"/>
        <FIELD NAME="usermodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="permission" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="cohort_id" TYPE="int" LENGTH="10"/>
        <FIELD NAME="roles" TYPE="char" LENGTH="255"/>
        <FIELD NAME="rolecontext" TYPE="text"/>
        <FIELD NAME="shortname" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text"/>
        <FIELD NAME="descriptionformat" TYPE="int" LENGTH="4"/>
        <FIELD NAME="dashicon" TYPE="char" LENGTH="50"/>
        <FIELD NAME="dashthumbnailimage" TYPE="int" LENGTH="15"/>
        <FIELD NAME="dashbgimage" TYPE="text"/>
        <FIELD NAME="secondarynav" TYPE="int" LENGTH="4"/>
        <FIELD NAME="coredash" TYPE="int" LENGTH="2"/>
        <FIELD NAME="includedblocks" TYPE="char" LENGTH="255"/>
        <FIELD NAME="displaydashboardtitle" TYPE="int" LENGTH="10" DEFAULT="0"/>
        <FIELD NAME="displaycta" TYPE="int" LENGTH="10" DEFAULT="0"/>
        <FIELD NAME="ctalink" TYPE="char" LENGTH="255" DEFAULT="enrolment"/>
        <FIELD NAME="ctacampaignid" TYPE="int" LENGTH="10" DEFAULT="0"/>
        <FIELD NAME="ctacustomurl" TYPE="char" LENGTH="255"/>
        <FIELD NAME="ctacustomurltext" TYPE="char" LENGTH="255"/>
        <FIELD NAME="contexttype" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="system"/>
        <FIELD NAME="categoryid" TYPE="int" LENGTH="10"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10"/>
        <FIELD NAME="redirecttodashboard" TYPE="int" LENGTH="4"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
