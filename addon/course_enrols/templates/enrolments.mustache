{{!
    @template dashaddon_course_enrols/enrolments

    Example context (json):
    {
        "sitefullname": "Moodle - 311",
		"courseurl": "https://localhost/moodle/course/view.php?id=2"
    }
}}
{{#data.capviewprofiledash}}
{{< block_dash/layout }}
    {{$body}}
    <div class="course-enrol-block">
        <div class="widget-course_enrols">
            <div class="course-enrols-courses-list">
                {{> dashaddon_course_enrols/coursecontent }}
            </div>
        </div>
    </div>
    {{/ body}}

{{/ block_dash/layout }}
{{/data.capviewprofiledash}}

{{#js}}
require(["dashaddon_course_enrols/enrolments"], function(DashEnrolments) {
    new DashEnrolments("#dash-{{data.uniqueid}}", "{{data.contextid}}", "{{data.uniqueid}}");
});
{{/js}}
