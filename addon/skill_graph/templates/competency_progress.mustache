{{!
    @template dashaddon_skill_graph/competency_progress

    Example context (json):
    {
    }

}}

{{^data.datasetcount}}
    {{#noresult}}{{{noresult}}}{{/noresult}}
{{/data.datasetcount}}

{{#data.datasetcount}}
<div class="competency-progress-dash-widget">

    <div class="competency-framework-progress">
        {{#data.frameworkprogress}}
        <div class="donut-competency-progress">
            <svg class="progress-circle" width="200px" height="200px" xmlns="http://www.w3.org/2000/svg">
                <circle class="progress-circle-back" cx="100" cy="90" r="80"></circle>
                <circle class="progress-circle-prog" cx="100" cy="90" r="80" stroke-dasharray="{{{progressarray}}} {{{dasharray}}}"></circle>
            </svg>
            <div class="competency-total-info">
                <span class="competency-framework-percent">{{{totalprogress}}}<i>%</i></span>
            </div>
        </div>
        {{/data.frameworkprogress}}
    </div>

    <div class="competency-list">
        <div class="competency-items-wrapper">
            {{#data.dataset}}
            <div class="competency-item">
                <div class="item-wrapper">
                    <!-- Competency related basic info like name and user proficient level -->
                    <div class="competency-basic-info d-flex">

                        <!-- Compentencyimage -->
                        <div class="competency-image-wrapper">
                            {{#competencyimage}}
                            <img src="{{{competencyimage}}}" alt="{{{shortname}}}" class="img-fluid competency-image" role="presentation">
                            {{/competencyimage}}
                        </div>

                        <div class="competency-info container no-gutters">
                            <!-- Competency name -->
                            <div class="competency-name text-left">
                                {{{shortname}}}
                            </div>

                            <div class="competency-progress-info row no-gutters">
                                <!-- competency user progress bar  -->
                                <div class="competency-progress col-9 col-sm-9 col-md-10 col-lg-11 mt-2 mb-2 pr-2">
                                    <div class="progress-bar-placeholder">
                                        <span class="progress-bar" role="progressbar" aria-valuenow="{{{progress}}}"
                                            style="width:{{{progress}}}%;background-color:{{{color}}};"></span>
                                    </div>
                                </div>

                                <!-- Competency progress detail -->
                                <div class="competency-progress-text col-sm-3 col-md-2 col-lg-1 col-3">
                                    <div class="progress-info-box">
                                        <span class="competency-percent">{{{progress}}} % </span>
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>

                </div>
            </div>
            {{/data.dataset}}
        </div>
    </div>
</div>
{{/data.datasetcount}}
