{{!
    @template dashaddon_learningpath/course_details

    This template for text track tab

    Variables optional for this template:

   Example context (json):
    {
        "courseimg": "http://example.com/courseimg.jpg",
        "progress": 50,
        "coursename": "Course Name",
        "summary": "Course summary text",
        "courseurl": "http://example.com/course/1",
        "completed": false,
        "notstarted": false,
        "prevcourse": "Previous Course Name",
        "prevcoursecircle": 1,
        "nextcourse": "Next Course Name",
        "nextcoursecircle": 3
    }

}}
<div class="grid-layout-block">
    <div class="grid-layout">
        <div class="card-img-top img-block">
            <img src="{{courseimg}}" alt="img-1">
        </div>

        <div class="progress-block">
            <div class="progress">
                <div class="progress-bar{{#progress}} progress-bg-success{{/progress}}{{^progress}} progress-not-started{{/progress}}" role="progressbar" style= "{{#progress}}width: {{progress}}%{{/progress}}"
                    aria-valuenow="{{progress}}" aria-valuemin="0" aria-valuemax="100">{{progress}}%</div>
            </div>
        </div>


        <div class="content-block card-body">
            <h2 class="card-title">{{{coursename}}}</h2>
            <div class="summary-block card-text">
                <p>{{{summary}}}</p>
            </div>

            {{#hasassignment}}
            <div class="assignment-info-block">
                <h6 class="assignment-info-title">{{#str}}assignmentinformation, block_dash{{/str}}</h6>
                <div class="assignment-info-grid">
                    {{#assignment.startdate}}
                    <div class="assignment-info-item">
                        <span class="assignment-info-label">{{#str}}assignment_startdate, block_dash{{/str}}:</span>
                        <span class="assignment-info-value">{{assignment.startdate}}</span>
                    </div>
                    {{/assignment.startdate}}

                    {{#assignment.duedate}}
                    <div class="assignment-info-item">
                        <span class="assignment-info-label">{{#str}}assignment_duedate, block_dash{{/str}}:</span>
                        <span class="assignment-info-value assignment-due">{{assignment.duedate}}</span>
                    </div>
                    {{/assignment.duedate}}

                    {{#assignment.enddate}}
                    <div class="assignment-info-item">
                        <span class="assignment-info-label">{{#str}}assignment_enddate, block_dash{{/str}}:</span>
                        <span class="assignment-info-value">{{assignment.enddate}}</span>
                    </div>
                    {{/assignment.enddate}}

                    {{#assignment.typename}}
                    <div class="assignment-info-item">
                        <span class="assignment-info-label">{{#str}}assignment_type, block_dash{{/str}}:</span>
                        <span class="assignment-info-value assignment-type-{{assignment.type}}">{{assignment.typename}}</span>
                    </div>
                    {{/assignment.typename}}

                    {{#assignment.priorityname}}
                    <div class="assignment-info-item">
                        <span class="assignment-info-label">{{#str}}assignment_priority, block_dash{{/str}}:</span>
                        <span class="assignment-info-value assignment-priority {{assignment.priorityclass}}">{{assignment.priorityname}}</span>
                    </div>
                    {{/assignment.priorityname}}

                    <div class="assignment-info-item assignment-tags-item">
                        <span class="assignment-info-label">{{#str}}assignment_tags, block_dash{{/str}}:</span>
                        <div class="assignment-tag-list">
                        {{#assignment.tags}}
                            <span class="assignment-info-value assignment-tags">{{name}}</span>
                        {{/assignment.tags}}
                        </div>
                    </div>
                </div>
            </div>
            {{/hasassignment}}

            <div class="btn-block">
            {{^notstarted}}
                <a href="{{courseurl}}" class="btn btn-primary">{{^completed}}{{#str}} resumecourse, block_dash{{/str}}{{/completed}} {{#completed}}{{#str}} completedcourse, block_dash{{/str}}{{/completed}}</a>
            {{/notstarted}}
            {{#notstarted}}
                <a href="{{courseurl}}" class="btn btn-primary">{{^completed}}{{#str}} startcourse, block_dash{{/str}}{{/completed}} {{#completed}}{{#str}} completedcourse, block_dash{{/str}}{{/completed}}</a>
            {{/notstarted}}
            </div>
        </div>
    </div>
    <nav aria-label="Page navigation">
        <ul class="pagination">
            {{#prevcourse}}
            <li class="page-item prev-item" data-circle="{{prevcoursecircle}}"><a class="page-link small" href="#"><i class="fa fa-angle-double-left"></i> {{#str}} previous {{/str}}</a>
                <div class="course-pagination bold">
                    <a href="#">{{prevcourse}}</a>
                </div>
            </li>
            {{/prevcourse}}

            {{#nextcourse}}
            <li class="page-item next-item" data-circle="{{nextcoursecircle}}"><a class="page-link small" href="#">{{#str}} next {{/str}} <i class="fa fa-angle-double-right"></i></a>
                <div class="course-pagination bold">
                    <a href="#">{{nextcourse}}</a>
                </div>
            </li>
            {{/nextcourse}}
        </ul>
    </nav>
</div>
