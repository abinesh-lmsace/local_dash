{{!
    @template dashaddon_content/content

    This template for text track tab

    Variables optional for this template:

    Example context (json):
    {
    }

}}
{{^data.configured}}
{{#noresult}}{{{noresult}}}{{/noresult}}
{{/data.configured}}

{{#data.configured}}
<div class="dashaddon-content dash-content-datasource container">
    <div class="filter-form">{{! filter form to refresh}}</div>
    {{#data.layout}}
        <div class="layout-section row">
            <!-- <div class="row"> -->
                {{#data.layouts}}
                <div class="content-layout-item col-12 {{colclass}} {{#edit}} layout-edit {{/edit}}" style="{{style}}" >
                    {{#editing}}
                    <span class="insert-dash-content" data-layoutid="{{layoutid}}" data-target="dash-insertcontent">
                        {{^edit}} {{#pix}} t/add, core, add-content {{/pix}} {{/edit}}
                        {{#edit}} {{#pix}} t/edit, core, edit-content {{/pix}} {{/edit}}
                        <span class="add-content">
                            {{^edit}}  {{#str}} addcontent, block_dash{{/str}} {{/edit}}
                            {{#edit}}  {{#str}} editcontent, block_dash{{/str}} {{/edit}}
                        </span>
                    </span>
                    {{/editing}}
                    <div class="content-wrapper ">
                        <div class="content position-relative" >
                            {{#showimage}} {{#backgroundimage}}
                            <img src="{{{backgroundimage}}}" alt="" class="img-block img-fluid" role="presentation">
                            {{/backgroundimage}} {{/showimage}}

                            {{#content}}
                            <div class="dashaddon-content-main">
                                {{{content}}}
                            </div>
                            {{/content}}
                        </div>
                    </div>
                </div>
                {{/data.layouts}}
            <!-- </div> -->
        </div>
    {{/data.layout}}
</div>
{{/data.configured}}

{{#editing}}
{{^data.layout}}
<div class="set-content">
    <span class="select-content-layout">{{#str}} selectlayout, block_dash {{/str}} </span>
</div>
{{/data.layout}}
{{/editing}}

{{#js}}
require(['dashaddon_content/content'], function(Content) {
    Content.init("{{data.uniqueid}}", "{{data.contextid}}");
});
{{/js}}
