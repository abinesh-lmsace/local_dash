{{!
    @template dashaddon_activity_completion/upgrade

    This template for text track tab

    Variables optional for this template:

    Example context (json):
    {
    }

}}

<div class="d-flex flex-column h-100" data-collapse="content">
    <div class="d-flex">
        <div class="d-flex flex-grow-1">

            {{#iseditable}}
                {{#scale}}
                    {{{label}}}{{{select}}}
                {{/scale}}
                {{^scale}}
                    <label for="{{id}}" class="accesshide">{{{label}}}</label>
                    <input id="{{id}}" name="{{name}}" type="{{#isnumeric}}number{{/isnumeric}}{{^isnumeric}}text{{/isnumeric}}" value="{{value}}" title="{{title}}" class="{{extraclasses}}" {{!
                        }} {{#minvalue}}min="{{.}}" {{/minvalue}} {{#maxvalue}}max="{{.}}" {{/maxvalue}} {{#isnumeric}}step="any"{{/isnumeric}}>
                {{/scale}}
            {{/iseditable}}

            {{^iseditable}}
                <div class="header">
                    {{{gradepassicon}}}
                    <span class="{{extraclasses}}">{{{text}}}</span>
                </div>
            {{/iseditable}}

        </div>
    </div>
</div>