{{!
    @template local_dash/progress_bar

    Example context (json):
    {
        "sitefullname": "Moodle - 311",
		"courseurl": "https://localhost/moodle/course/view.php?id=2"
    }
}}
<div class="progress">
    <div class="progress-bar" role="progressbar" style="width: {{#percentage}}{{percentage}}{{/percentage}}{{^percentage}}0{{/percentage}}"
        aria-valuenow="{{#percentage}}{{percentage}}{{/percentage}}{{^percentage}}0{{/percentage}}"
        aria-valuemin="0" aria-valuemax="100">
    </div>
</div>
